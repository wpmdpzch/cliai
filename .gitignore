# =========================================
# ShellMind - .gitignore
# =========================================

# ---- Go ----
# Binary
cliai-go/cliai
shellmind/shellmind
shellmind/shellmind.exe
shellmind/*.exe
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Output of go coverage
*.out
coverage.txt

# Go vendor
shellmind/vendor/
vendor/

# Build output
dist/
build/

# ---- Python ----
# Byte-compiled
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# pip log
pip-log.txt
pip-delete-this-directory.txt

# pyproject.toml local
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
*.cover

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ---- Rust ----
# Cargo build
shellmind-rs/target/
target/
**/target/

# Cargo.lock (if using workspace, keep this commented)
# Cargo.lock

# ---- IDE ----
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---- Config (local) ----
*.local.yaml
*.local.yml
config.local.*
.env
.env.local

# ---- Logs ----
*.log
logs/

# ---- Temp ----
tmp/
temp/
*.tmp
*.json
test.json
